# ============================================================
# HOSTINGER SHARED HOSTING — single .htaccess for the docroot
#
# This file REPLACES the original "root project .htaccess" on
# the server. It must:
#   1. SERVE the app (directory listing off, index file set, rewrite clean)
#   2. DENY all the private paths (/_app/, /vendor/, etc.)
#   3. REDIRECT HTTP -> HTTPS when SSL is enabled
#   4. SET security headers
#
# This is the public/.htaccess merged with the safety-net
# rules from the project root .htaccess.
# ============================================================

# Disable directory listing
Options -Indexes

# Make sure index.php is preferred
DirectoryIndex index.php index.html

# Allow .htaccess overrides
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# =============================================================
# 1. REDIRECTS — HTTP -> HTTPS (only outside localhost)
# =============================================================
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# =============================================================
# 2. CUSTOM ERROR PAGES
# =============================================================

# Primary: mod_rewrite catch-all — works even without AllowOverride FileInfo
<IfModule mod_rewrite.c>
    # 404 — requested file/dir does not exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/404\.php$
    RewriteCond %{REQUEST_URI} !^/500\.php$
    RewriteRule ^ 404.php [L]
</IfModule>

# Fallback: ErrorDocument for server-level errors (requires AllowOverride FileInfo)
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

# =============================================================
# 3. SECURITY HEADERS (LiteSpeed compatible)
# =============================================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Only set HSTS on HTTPS
    <IfModule mod_rewrite.c>
        RewriteCond %{HTTPS} on
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    </IfModule>

    # Content-Security-Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com; frame-src https://www.googletagmanager.com;"

    Header unset X-Powered-By
    Header unset Server
</IfModule>

# =============================================================
# 4. DENY DOTFILES + COMPOSER FILES (project-root style)
# =============================================================
<FilesMatch "^(\.|composer\.|schema\.)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(sqlite|sqlite3|sqlite-journal|sqlite-wal|sqlite-shm|log|md|lock|example|sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# =============================================================
# 5. DENY SENSITIVE URL PATHS (catches /vendor, /data, /_app/src, etc.)
# =============================================================
RedirectMatch 403 "/\.env(/|$)"
RedirectMatch 403 "/_env(/|$)"
RedirectMatch 403 "/\.env\.example(/|$)"
RedirectMatch 403 "/vendor(/|$)"
RedirectMatch 403 "/src(/|$)"
RedirectMatch 403 "/data(/|$)"
RedirectMatch 403 "/logs(/|$)"
RedirectMatch 403 "/views(/|$)"
RedirectMatch 403 "/\.git(/|$)"
RedirectMatch 403 "/\.vscode(/|$)"
RedirectMatch 403 "/\.idea(/|$)"
RedirectMatch 403 "/composer\.(json|lock|phar)(/|$)"
RedirectMatch 403 "/schema\.sql(/|$)"
RedirectMatch 403 "/_app(/|$)"
RedirectMatch 403 "/scripts(/|$)"
RedirectMatch 403 "/diag(/|$)"

# =============================================================
# 6. DENY PHP EXECUTION IN /data AND /logs (defense in depth)
# =============================================================
RedirectMatch 403 ^/(data|logs)/.+\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$

# =============================================================
# 7. CACHING
# =============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# =============================================================
# 8. MIME TYPES
# =============================================================
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType application/json .json
    AddType font/woff .woff
    AddType font/woff2 .woff2
</IfModule>
