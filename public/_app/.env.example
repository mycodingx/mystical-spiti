# =============================================================
# Mystical Expedition - Environment Configuration
# =============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real credentials.
# =============================================================

# Application
# - Use http://localhost:8080/mystical/public  for local XAMPP on port 8080
# - Use https://your-subdomain.example.com for production
APP_ENV=production
APP_DEBUG=false
APP_URL=https://book.mysticalexpedition.com
APP_NAME="Mystical Expedition"

# Business contact (shown to users)
BUSINESS_NAME="Mystical Expedition"
BUSINESS_EMAIL="info@mysticalexpedition.com"
BUSINESS_PHONE="+91-8219000937"
BUSINESS_ADDRESS="NH-22, opposite SBI Bank, Shoghi, Himachal Pradesh 171219"
BUSINESS_WHATSAPP="918219000937"

# Where leads are emailed to (usually same as BUSINESS_EMAIL)
LEADS_NOTIFY_EMAIL="info@mysticalexpedition.com"

# SMTP (Hostinger)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@mysticalexpedition.com
MAIL_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@mysticalexpedition.com
MAIL_FROM_NAME="Mystical Expedition"

# Lead capture
LEADS_RATE_LIMIT_PER_HOUR=5

# Database - path relative to project root (NOT public/)
DB_PATH=data/leads.sqlite